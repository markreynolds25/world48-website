# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit the real file.

# Google Sheets (service account) — single-line JSON
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A:O

# Optional: Google Analytics (Phase 2)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
